install.packages("shiny"
library(shiny)
install.packages("shiny")
library(shiny)
library(shiny)
ui <- fluidPage(
titlePanel("Ejemplo Shiny"),
sidebarLayout(
sidebarPanel(
selectInput(
"variable",
"Variable:",
choices = c("mpg", "hp", "wt", "qsec")
),
sliderInput(
"bins",
"Barras:",
min = 5,
max = 20,
value = 10
)
),
mainPanel(
plotOutput("histograma"),
tableOutput("tabla")
)
)
)
server <- function(input, output) {
output$histograma <- renderPlot({
hist(
mtcars[[input$variable]],
breaks = input$bins,
col = "lightblue",
border = "black",
main = paste("Histograma de", input$variable),
xlab = input$variable
)
})
output$tabla <- renderTable({
datos <- head(mtcars[, input$variable, drop = FALSE])
colnames(datos) <- input$variable
datos
}, rownames = TRUE)
}
shinyApp(ui, server)
