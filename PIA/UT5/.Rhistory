genera_columnas_sinbucle <- function(df, k) {
n_cols <- ncol(df)
# Suma de las 2 cols anteriores
suma <- df[, n_cols - 1] + df[, n_cols]
# Añadir la columna
df[, paste0("adic_", 1:k)] <- suma
return(df)
}
