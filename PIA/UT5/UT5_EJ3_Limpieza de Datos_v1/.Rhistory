ggplot(encuesta_genero, aes(x = Genero, y = Ingreso_medio)) + geom_bar(stat = "identity", colours='red', size= 33)
ggplot(encuesta_genero, aes(x = Genero, y = Ingreso_medio)) + geom_bar(stat = "identity", colour='red', size= 33)
